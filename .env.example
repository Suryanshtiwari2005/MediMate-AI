# ──────────────────────────────────────────────
# Django Core
# ──────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend URL (for OAuth redirect)
FRONTEND_URL=http://localhost:5173

# ──────────────────────────────────────────────
# Google OAuth 2.0
# ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback/

# ──────────────────────────────────────────────
# JWT Settings (optional overrides)
# ──────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ──────────────────────────────────────────────
# WhatsApp — CallMeBot
# ──────────────────────────────────────────────
CALLMEBOT_APIKEY=your-callmebot-apikey

# ──────────────────────────────────────────────
# Hugging Face — AI Tips
# ──────────────────────────────────────────────
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# Twilio — Bot Voice Calls
# ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1xxxxxxxxxx

# ──────────────────────────────────────────────
# VAPID — Push Notifications (optional)
# ──────────────────────────────────────────────
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CLAIM_EMAIL=your@email.com
